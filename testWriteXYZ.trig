test:shacl {

    test:testWriteXYZShape a sh:NodeShape ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2026-04-02T23:28:57.992567+02:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2026-04-02T23:28:57.992567+02:00"^^xsd:dateTime ;
        oldap:appliesToProperty test:GAGA ;
        sh:property [
            sh:path test:testWriteXYZ ;
            sh:class test:GUGUS ;
            sh:name """Annotations"""@en, """Annotations"""@de ;
            sh:description """An annotation"""@en, """Eine Annotation"""@de ;
            sh:maxCount "1"^^xsd:integer ;
            sh:order "42.0"^^xsd:decimal ;
        ] .
}
test:onto {
    test:testWriteXYZ rdf:type owl:ObjectProperty, owl:SymmetricProperty .
}
