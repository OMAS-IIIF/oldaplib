oldap:admin {

    oldap:Test a oldap:Project ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        oldap:projectShortName "test"^^xsd:NCName ;
        oldap:namespaceIri <http://oldap.org/test#> ;
        rdfs:label "Test"@en, "Test"@de, "Test"@fr, "Test"@it ;
        rdfs:comment "For testing purposes"@en ;
        oldap:projectStart "2024-01-01"^^xsd:date .

}

test:shacl {

    test:shapes schema:version "0.1.0"^^xsd:string .

    test:MammalShape a sh:NodeShape ;
        sh:targetClass test:Mammal ;
        dcterms:created "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        sh:node oldap:ThingShape ;
        sh:property [
            sh:path test:name ;
            sh:datatype xsd:string ;
       ] .

    test:CatShape a sh:NodeShape ;
        sh:targetClass test:Cat ;
        dcterms:created "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        sh:node oldap:ThingShape, test:MammalShape ;
        sh:property [
            sh:path test:subName ;
            sh:datatype xsd:string ;
        ] .

    test:MediaLibraryEntryShape a sh:NodeShape ;
        sh:targetClass test:MediaLibraryEntry ;
        dcterms:created "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        sh:node oldap:ThingShape, shared:MediaObjectShape ;
        sh:property [
            sh:path test:caption ;
            sh:datatype xsd:string ;
        ] .

    test:LocationShape a sh:NodeShape ;
        sh:targetClass test:Location ;
        dcterms:created "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        sh:node oldap:ThingShape ;
        rdfs:label "Location"@en, "Location"@de ;
        rdfs:comment "A location on Earth"@en, "Ein ort auf der Erde"@de ;
        sh:closed "true"^^xsd:boolean ;
        sh:property [
            sh:path test:loc ;
            sh:datatype geo:wktLiteral ;
        ] .


    test:PersonShape a sh:NodeShape ;
        sh:targetClass test:Person ;
        dcterms:created "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        sh:node oldap:ThingShape ;
        rdfs:label "Project"@en, "Projekt"@de ;
        rdfs:comment "A page of a book"@en, "Seite eines Buches"@de ;
        sh:closed "true"^^xsd:boolean ;
        sh:property [
                sh:path schema:familyName ;
                sh:datatype xsd:string ;
                sh:minCount "1"^^xsd:integer ;
                sh:maxCount "1"^^xsd:integer ;
            ] ;
        sh:property
            [
                sh:path schema:givenName ;
                sh:datatype xsd:string ;
                sh:minCount "1"^^xsd:integer ;
            ] .

        test:PageShape a sh:NodeShape ;
            sh:targetClass test:Page ;
            dcterms:created "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
            dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
            dcterms:modified "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
            dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
            sh:node oldap:ThingShape ;
            rdfs:label "Project"@en, "Projekt"@de ;
            rdfs:comment "A page of a book"@en, "Seite eines Buches"@de ;
            sh:closed "true"^^xsd:boolean ;
            sh:property [
                    # PropertyClass.property_node_shacl()
                    sh:path test:pageDesignation ;
                    sh:datatype xsd:string ;
                    sh:name "Page designation"@en, "Seitenbezeichnung"@de ;
                    sh:order "1.0"^^xsd:decimal ;
                    sh:minCount "1"^^xsd:integer ;
                ] ;
            sh:property
                [
                    # PropertyClass.property_node_shacl()
                    sh:path test:pageNum ;
                    sh:datatype xsd:positiveInteger ;
                    sh:name "Pagenumber"@en, "Seitennummer"@de ;
                    sh:description "consecutive numbering of pages"@en, "Konsekutive Nummerierung der Seiten"@de ;
                    sh:order "2.0"^^xsd:decimal ;
                    sh:minCount "1"^^xsd:integer ;
                    sh:maxCount "1"^^xsd:integer ;
                ] ;
            sh:property
                [
                    # PropertyClass.property_node_shacl()
                    sh:path test:pageDescription ;
                    sh:datatype rdf:langString ;
                    sh:order "3.0"^^xsd:decimal ;
                    sh:languageIn ("en"^^xsd:string "de"^^xsd:string) ;
                    sh:uniqueLang "true"^^xsd:boolean ;
                ] ;
            sh:property
                [
                    # PropertyClass.property_node_shacl()
                    sh:path test:pageContent ;
                    sh:datatype xsd:string ;
                    sh:order "4.0"^^xsd:decimal ;
                    sh:maxCount "1"^^xsd:integer ;
                ] ;
            sh:property
                [
                    # PropertyClass.property_node_shacl()
                    sh:path test:pageInBook ;
                    sh:class test:Book ;
                    sh:order "5.0"^^xsd:decimal ;
                    sh:minCount "1"^^xsd:integer ;
                    sh:maxCount "1"^^xsd:integer ;
                ] .

        test:BookShape a sh:NodeShape ;
            sh:targetClass test:Book ;
            dcterms:created "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
            dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
            dcterms:modified "2024-05-16T18:38:25.551434"^^xsd:dateTime ;
