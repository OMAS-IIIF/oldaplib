test:onto {
    test:ontology owl:type owl:Ontology ;
    owl:versionInfo "0.1.0"^^xsd:string .

    test:Mammal rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing .

    test:Cat rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing, test:Mammal .

    test:MediaLibraryEntry rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing, shared:MediaObject .


    test:name rdf:type owl:DatatypeProperty .

    test:subName rdf:type owl:DatatypeProperty .

    test:caption rdf:type owl:DatatypeProperty .


    test:loc rdf:type owl:DatatypeProperty .

    test:Location rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing .


    test:Person rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing.


    test:pageDesignation rdf:type owl:DatatypeProperty .

    test:pageDescription rdf:type owl:DatatypeProperty .

    test:pageNum rdf:type owl:DatatypeProperty .

    test:pageContent rdf:type owl:DatatypeProperty .

    test:pageInBook rdf:type owl:ObjectProperty .

    test:Page rdf:type owl:Class ;
         rdfs:subClassOf oldap:Thing .

    test:title rdf:type owl:DatatypeProperty .

