@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.org/> .
@prefix schema: <https://schema.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix schemas: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix shared: <http://oldap.org/shared#> .
@prefix oldap: <http://oldap.org/base#> .
@prefix ex: <http://example.com/ns/> .


oldap:admin {

    oldap:Example a oldap:Project ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        oldap:projectShortName "example"^^xsd:NCName ;
        oldap:namespaceIri <http://example.com/ns/> ;
        rdfs:label "Test"@en, "Test"@de, "Test"@fr, "Test"@it ;
        rdfs:comment "For testing purposes"@en ;
        oldap:projectStart "2024-01-01"^^xsd:date .

}

ex:shacl {
    ex:shapes schema:version "0.1.0"^^xsd:string .

    ex:TestObjShape a sh:NodeShape ;
        sh:targetClass ex:TestObj;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        sh:node oldap:ThingShape, schema:PersonShape;
        sh:property [
            sh:path ex:hasTestProp ;
            sh:datatype xsd:string ;
        ] .
}

ex:onto {
    shared:ontology rdf:type owl:Ontology ;
        owl:versionInfo "0.1.0"^^xsd:string .

    ex:TestObj rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing, schema:Person .

    ex:hasTestProp rdf:type owl:DatatypeProperty .
}

