:shacl {

    :shapes schema:version "0.1.0"^^xsd:string .

    :crm a oldap:ExternalOntology ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        oldap:prefix "crm"^^xsd:NCName ;
        oldap:namespaceIri <http://www.cidoc-crm.org/cidoc-crm/> ;
        rdfs:label "CIDOC-CRM"@en, "CIDOC-CRM"@de, "CIDOC-CRM"@fr .

    :edm a oldap:ExternalOntology ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        oldap:prefix "edm"^^xsd:NCName ;
        oldap:namespaceIri <http://www.europeana.eu/schemas/edm/> ;
        rdfs:label "Europeana Ontology"@en, "Europeana Ontologie"@de, "Ontologie d l'Europeana"@fr ;
        oldap:proposedObjectPropertyClass "hasMet"^^xsd:NCName, "occuredAt"^^xsd:NCName, "wasPresetAt"^^xsd:NCName ;
        oldap:proposedDatatypePropertyClass "hasType"^^xsd:NCName, "dataProvide"^^xsd:NCName .



    :testMyResShape a sh:NodeShape ;
        sh:targetClass :testMyRes ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        rdfs:label "My Resource"@en, "Meine Ressource"@de, "Ma Resource"@fr ;
        rdfs:comment "Resource for testing..."^^xsd:string ;
        sh:property
            [
                sh:path :hasText ;
                sh:datatype rdf:langString ;
                sh:languageIn ("de"^^xsd:string "en"^^xsd:string) ;
                sh:maxCount "1"^^xsd:integer ;
                sh:minCount "1"^^xsd:integer ;
                sh:name "A text"@en, "Ein Text"@de ;
                sh:description "A longer text..."^^xsd:string ;
                sh:order "1"^^xsd:decimal ;
            ] ;
        sh:property
            [
                sh:path :hasEnum ;
                sh:datatype xsd:string ;
                sh:in ('red'^^xsd:string 'green'^^xsd:string 'blue'^^xsd:string 'yellow'^^xsd:string)
            ] ;
        sh:closed "true"^^xsd:boolean .

    :testMyResMinimalShape a sh:NodeShape ;
        sh:targetClass :testMyResMinimal ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        sh:property
            [
                sh:path :hasMinimal ;
                sh:datatype xsd:string ;
            ] ;
        sh:closed "true"^^xsd:boolean .

    :testMyResMinimalAShape a sh:NodeShape ;
        sh:targetClass :testMyResMinimalA ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        sh:property
            [
                sh:path :hasMinimalA ;
                sh:datatype xsd:string ;
            ] ;
        sh:closed "true"^^xsd:boolean .

    :testMyResMinimalBShape a sh:NodeShape ;
        sh:targetClass :testMyResMinimalB ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        sh:property
            [
                sh:path :hasMinimalB ;
                sh:datatype xsd:string ;
            ] ;
        sh:closed "true"^^xsd:boolean .

    :testMyResMinimalCShape a sh:NodeShape ;
        sh:targetClass :testMyResMinimalC ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        sh:property
            [
                sh:path :hasMinimalC ;
                sh:datatype xsd:string ;
            ] ;
        sh:closed "true"^^xsd:boolean .

    :testMyResInheritShape a sh:NodeShape ;
        sh:targetClass :testMyResInherit ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        sh:node :testMyResMinimalShape, oldap:ThingShape ;
        sh:property
            [
                sh:path :hasMore ;
                sh:datatype xsd:string ;
            ] ;
        sh:closed "true"^^xsd:boolean .
}

:onto {

    :ontology rdf:type owl:Ontology ;
        owl:versionInfo "0.1.0"^^xsd:string .


    :comment rdf:type owl:DatatypeProperty .

    :test rdf:type owl:DatatypeProperty .

    :enum rdf:type owl:DatatypeProperty .

    :hasText rdf:type owl:DatatypeProperty .

    :hasEnum rdf:type owl:DatatypeProperty .

    :hasMinimal a owl:DatatypeProperty .

    :hasMinimalA a owl:DatatypeProperty .

    :hasMinimalB a owl:DatatypeProperty .

    :hasMinimalC a owl:DatatypeProperty .

    :hasMore a owl:DatatypeProperty .


    :testMyRes a owl:Class ;
        rdfs:subClassOf oldap:Thing .

    :testMyResMinimal a owl:Class .

    :testMyResMinimalA a owl:Class .

    :testMyResMinimalB a owl:Class .

    :testMyResMinimalC a owl:Class .

    :testMyResInherit a owl:Class ;
        rdfs:subClassOf :testMyResMinimal, oldap:Thing .

}

