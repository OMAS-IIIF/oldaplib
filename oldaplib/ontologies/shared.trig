shared:onto {
    shared:ontology rdf:type owl:Ontology ;
        owl:versionInfo "0.1.0"^^xsd:string .

    ###########################################################################
    # Calendar vocabulary for historical dating
    ###########################################################################

    oldap:Calendar rdf:type owl:Class ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        rdfs:label "Calendar"@en, "Kalender"@de, "Calendrier"@fr, "Calendario"@it ;
        rdfs:comment "Controlled vocabulary of calendrical systems used for historical dating."@en,
                     "Kontrolliertes Vokabular der Kalendersysteme für historische Datierungen."@de,
                     "Vocabulaire contrôlé des systèmes calendaires utilisés pour la datation historique."@fr,
                     "Vocabolario controllato dei sistemi di calendario usati per la datazione storica."@it .

    oldap:GregorianCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        rdfs:label "Gregorian calendar"@en, "Gregorianischer Kalender"@de, "Calendrier grégorien"@fr, "Calendario gregoriano"@it ;
        rdfs:comment "The Gregorian calendar."@en,
                     "Der gregorianische Kalender."@de,
                     "Le calendrier grégorien."@fr,
                     "Il calendario gregoriano."@it .

    oldap:JulianCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        rdfs:label "Julian calendar"@en, "Julianischer Kalender"@de, "Calendrier julien"@fr, "Calendario giuliano"@it ;
        rdfs:comment "The Julian calendar."@en,
                     "Der julianische Kalender."@de,
                     "Le calendrier julien."@fr,
                     "Il calendario giuliano."@it .

    oldap:HebrewCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        rdfs:label "Hebrew calendar"@en, "Hebräischer Kalender"@de, "Calendrier hébraïque"@fr, "Calendario ebraico"@it ;
        rdfs:comment "The Hebrew calendar."@en,
                     "Der hebräische Kalender."@de,
                     "Le calendrier hébraïque."@fr,
                     "Il calendario ebraico."@it .

    oldap:IslamicCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        rdfs:label "Islamic calendar"@en, "Islamischer Kalender"@de, "Calendrier islamique"@fr, "Calendario islamico"@it ;
        rdfs:comment "The Islamic calendar."@en,
                     "Der islamische Kalender."@de,
                     "Le calendrier islamique."@fr,
                     "Il calendario islamico."@it .

    oldap:PersianCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        rdfs:label "Persian calendar"@en, "Persischer Kalender"@de, "Calendrier persan"@fr, "Calendario persiano"@it ;
        rdfs:comment "The Persian calendar."@en,
                     "Der persische Kalender."@de,
                     "Le calendrier persan."@fr,
                     "Il calendario persiano."@it .

    oldap:inCalendar rdf:type owl:ObjectProperty ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00Z"^^xsd:dateTime ;
        rdfs:domain oldap:Dating ;
        rdfs:range oldap:Calendar ;
        rdfs:label "calendar"@en, "Kalender"@de, "calendrier"@fr, "calendario"@it ;
        rdfs:comment "Links a dating resource to the calendrical system in which it is expressed."@en,
                     "Verknüpft eine Datierungsressource mit dem Kalendersystem, in dem sie ausgedrückt ist."@de,
                     "Relie une ressource de datation au système calendaire dans lequel elle est exprimée."@fr,
                     "Collega una risorsa di datazione al sistema di calendario in cui è espressa."@it .

    ###############################################################################
    # Generic comment property
    ###############################################################################

    :commentString rdf:type rdf:Property, owl:DatatypeProperty ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2023-11-04T12:00:00+00:00"^^xsd:dateTime ;
        rdfs:range xsd:string .

    ###############################################################################
    # Properties used for :ChronologyObject
    ###############################################################################

