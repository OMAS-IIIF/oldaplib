            sh:in (
                dcmitype:Collection
                dcmitype:Dataset
                dcmitype:StillImage
                dcmitype:Image
                dcmitype:MovingImage
                dcmitype:Sound
                dcmitype:Text
            ) ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:order "0.5"^^xsd:decimal ;
        ] ;
        sh:property [
