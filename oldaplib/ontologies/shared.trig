@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcmitype: <http://purl.org/dc/dcmitype/> .
@prefix schema: <http://schema.org/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix sf:     <http://www.opengis.net/ont/sf#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix oldap: <http://oldap.org/base#> .

@prefix shared: <http://oldap.org/shared#> .
@prefix : <http://oldap.org/shared#> .

shared:shacl {
    shared:shapes schema:version "0.1.0"^^xsd:string .


    ###########################################################################
    # Chronology Date definitions
    ###########################################################################
    oldap:DatingShape a sh:NodeShape ;
        sh:targetClass oldap:Dating ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:created "2025-01-01T00:00:00+02:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2025-01-01T00:00:00+02:00"^^xsd:dateTime ;
        rdfs:label "Dating object"@en, "Datumsobjekt"@de, "Objet de date"@fr, "Oggetto data"@it ;
        sh:closed "true"^^xsd:boolean ;
        sh:node oldap:ThingShape ;
        sh:property [
            sh:path oldap:verbatimDate ;
            sh:name "Verbatim date"@en, "Wörtliche Zeitangabe"@de, "Citation littérale"@fr, "Tempo letterale"@it ;
            sh:maxCount "1"^^xsd:integer ;
            sh:datatype xsd:string ;
            sh:order 1.0 ;
        ] ;
        sh:property [
            sh:path oldap:normalizedBegin ;
            sh:name "Normalized begin (ISO Gregorian)"@en,
                        "Normierter Beginn (ISO-Gregorian)"@de,
                        "Début normalisé (calendrier grégorien ISO)"@fr,
                        "Inizio normalizzato (calendario gregoriano ISO)"@it ;
            sh:maxCount "1"^^xsd:integer ;
            sh:datatype xsd:date ;
            sh:order 2.0 ;
        ] ;
        sh:property [
            sh:path oldap:normalizedEnd ;
            sh:name "Normalized end (ISO Gregorian)"@en, "Normalisiertes Ende (ISO-Gregorian)"@de, "Fin normalisée (calendrier grégorien ISO)"@fr, "Fine normalizzata (calendario gregoriano ISO)"@it ;
            sh:maxCount "1"^^xsd:nonNegativeInteger ;
            sh:datatype xsd:date ;
            sh:order 3.0 ;
        ] ;
        sh:property [
            sh:path oldap:inCalendar ;
            sh:name "Calendar of the original date"@en, "Kalender des ursprünglichen Datums"@de, "Calendrier de la date d'origine"@fr, "Calendario della data originale"@it ;
            sh:maxCount "1"^^xsd:nonNegativeInteger ;
            sh:class oldap:Calendar ;
            sh:in (oldap:GregorianCalendar oldap:JulianCalendar oldap:HebrewCalendar oldap:IslamicCalendar oldap:PersianCalendar) ;
            sh:order 4.0 ;
       ] ;
        sh:property [
            sh:path oldap:before ;
            sh:class oldap:Dating ;
            sh:name "before other event"@en, "vor einem anderen Ereignis"@de, "avant un autre événement"@fr, "prima di un altro evento"@it ;
            sh:order 5.0 ;
        ] .

    ###############################################################################
    # Media object
    ###############################################################################

    shared:MediaObjectShape a sh:NodeShape ;
        sh:targetClass shared:MediaObject ;
        dcterms:created "2025-01-01T00:00:00+02:00"^^xsd:dateTime ;
        dcterms:creator <https://orcid.org/0000-0003-1681-4036> ;
        dcterms:modified "2025-01-01T00:00:00+02:00"^^xsd:dateTime ;
        dcterms:contributor <https://orcid.org/0000-0003-1681-4036> ;
        rdfs:label "MediaObject"@en, "Medienobjekt"@de, "MediaObject"@fr, "MediaObject"@it ;
        sh:closed "true"^^xsd:boolean ;
        sh:node oldap:ThingShape ;
        sh:property [
            sh:path dcterms:type ;
            sh:nodeKind sh:IRI ;
            sh:in (
                dcmitype:Collection
                dcmitype:Dataset
                dcmitype:StillImage
                dcmitype:Image
                dcmitype:MovingImage
                dcmitype:Sound
                dcmitype:Text
            ) ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:order "1.0"^^xsd:decimal ;
        ] ;
        sh:property [
                sh:path shared:originalName ;
                sh:datatype xsd:string ;
                sh:name "Original Filename"@en, "Originaler Dateiname"@de, "Nom orignal du fichier"@fr, "Nome documento originale"@it ;
                sh:minCount "1"^^xsd:integer ;
                sh:maxCount "1"^^xsd:integer ;
                sh:order "2.0"^^xsd:decimal ;
        ] ;
        sh:property [
                sh:path shared:originalMimeType ;
                sh:datatype xsd:string ;
                sh:name "Original mimetype"@en, "Originaler Mimetype"@de, "Mimetype original"@fr, "Mimetype originale"@it ;
                sh:minCount "1"^^xsd:integer ;
                sh:maxCount "1"^^xsd:integer ;
                sh:order "3.0"^^xsd:decimal ;
        ] ;
        sh:property [
                sh:path shared:serverUrl ;
                sh:datatype xsd:anyURI ;
                sh:name "Server URL"@en, "URL des servers"@de, "Server URL"@fr, "Server URL"@it ;
                sh:minCount "1"^^xsd:integer ;
                sh:maxCount "1"^^xsd:integer ;
                sh:order "4.0"^^xsd:decimal ;
        ] ;
        sh:property [
                sh:path shared:assetId ;
                sh:datatype xsd:string ;
                sh:name "Image ID"@en, "ID des Bilder"@de, "ID de l\'image"@fr, "ID de l\'immagine"@it ;
                sh:minCount "1"^^xsd:integer ;
                sh:maxCount "1"^^xsd:integer ;
                sh:order "5.0"^^xsd:decimal ;
        ] ;
        sh:property [
            sh:path shared:protocol ;
            sh:datatype xsd:string ;
            sh:in ( 'iiif' 'http' 'custom') ;
            sh:minCount "1"^^xsd:integer ;
            sh:maxCount "1"^^xsd:integer ;
            sh:order "6.0"^^xsd:decimal ;
        ] ;
        sh:property [
            sh:path shared:derivativeName ;
            sh:datatype xsd:string ;
            sh:minCount "1"^^xsd:integer ;
            sh:maxCount "1"^^xsd:integer ;
            sh:order "7.0"^^xsd:decimal ;
        ] ;
        sh:property [
            sh:path shared:path ;
            sh:datatype xsd:string ;
            sh:minCount "1"^^xsd:integer ;
            sh:maxCount "1"^^xsd:integer ;
            sh:order "8.0"^^xsd:decimal ;
       ] .
}

shared:onto {
    shared:ontology rdf:type owl:Ontology ;
        owl:versionInfo "0.1.0"^^xsd:string .

    ###########################################################################
    # Calendar vocabulary for historical dating
    ###########################################################################

    oldap:Calendar rdf:type owl:Class ;
        rdfs:label "Calendar"@en, "Kalender"@de, "Calendrier"@fr, "Calendario"@it ;
        rdfs:comment "Controlled vocabulary of calendrical systems used for historical dating."@en,
                     "Kontrolliertes Vokabular der Kalendersysteme für historische Datierungen."@de,
                     "Vocabulaire contrôlé des systèmes calendaires utilisés pour la datation historique."@fr,
                     "Vocabolario controllato dei sistemi di calendario usati per la datazione storica."@it .

    oldap:GregorianCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        rdfs:label "Gregorian calendar"@en, "Gregorianischer Kalender"@de, "Calendrier grégorien"@fr, "Calendario gregoriano"@it ;
        rdfs:comment "The Gregorian calendar."@en,
                     "Der gregorianische Kalender."@de,
                     "Le calendrier grégorien."@fr,
                     "Il calendario gregoriano."@it .

    oldap:JulianCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        rdfs:label "Julian calendar"@en, "Julianischer Kalender"@de, "Calendrier julien"@fr, "Calendario giuliano"@it ;
        rdfs:comment "The Julian calendar."@en,
                     "Der julianische Kalender."@de,
                     "Le calendrier julien."@fr,
                     "Il calendario giuliano."@it .

    oldap:HebrewCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        rdfs:label "Hebrew calendar"@en, "Hebräischer Kalender"@de, "Calendrier hébraïque"@fr, "Calendario ebraico"@it ;
        rdfs:comment "The Hebrew calendar."@en,
                     "Der hebräische Kalender."@de,
                     "Le calendrier hébraïque."@fr,
                     "Il calendario ebraico."@it .

    oldap:IslamicCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        rdfs:label "Islamic calendar"@en, "Islamischer Kalender"@de, "Calendrier islamique"@fr, "Calendario islamico"@it ;
        rdfs:comment "The Islamic calendar."@en,
                     "Der islamische Kalender."@de,
                     "Le calendrier islamique."@fr,
                     "Il calendario islamico."@it .

    oldap:PersianCalendar rdf:type oldap:Calendar, owl:NamedIndividual ;
        rdfs:label "Persian calendar"@en, "Persischer Kalender"@de, "Calendrier persan"@fr, "Calendario persiano"@it ;
        rdfs:comment "The Persian calendar."@en,
                     "Der persische Kalender."@de,
                     "Le calendrier persan."@fr,
                     "Il calendario persiano."@it .

    oldap:inCalendar rdf:type owl:ObjectProperty ;
        rdfs:domain oldap:Dating ;
        rdfs:range oldap:Calendar ;
        rdfs:label "calendar"@en, "Kalender"@de, "calendrier"@fr, "calendario"@it ;
        rdfs:comment "Links a dating resource to the calendrical system in which it is expressed."@en,
                     "Verknüpft eine Datierungsressource mit dem Kalendersystem, in dem sie ausgedrückt ist."@de,
                     "Relie une ressource de datation au système calendaire dans lequel elle est exprimée."@fr,
                     "Collega una risorsa di datazione al sistema di calendario in cui è espressa."@it .


    ###############################################################################
    # Properties used for :ChronologyObject
    ###############################################################################

    oldap:verbatimDate rdf:type owl:DatatypeProperty .

    oldap:normalizedBegin rdf:type owl:DatatypeProperty .

    oldap:normalizedEnd rdf:type owl:DatatypeProperty .

    oldap:before rdf:type owl:ObjectProperty, owl:TransitiveProperty .

    ###########################################################################
    # Chronology Date Resource
    ###########################################################################

    oldap:Dating rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing .

    ###########################################################################
    # Media object
    ###########################################################################

    dcterms:type rdf:type owl:ObjectProperty .

    shared:originalName rdf:type owl:DatatypeProperty .

    shared:originalMimeType rdf:type owl:DatatypeProperty .

    shared:serverUrl rdf:type owl:DatatypeProperty .

    shared:assetId rdf:type owl:DatatypeProperty .

    shared:derivativeName rdf:type owl:DatatypeProperty .

    shared:protocol rdf:type owl:DatatypeProperty .

    shared:path rdf:type owl:DatatypeProperty .

    shared:MediaObject rdf:type owl:Class ;
        rdfs:subClassOf oldap:Thing .

}

